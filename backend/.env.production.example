# Agrinext Backend - Production Environment Configuration
# Copy this file to .env.production and fill in the values

# Environment
NODE_ENV=production
PORT=3000

# Database Configuration
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_NAME=agrinext
DB_USER=agrinextadmin
DB_PASSWORD=your-secure-database-password

# JWT Configuration
# Generate secure random strings for these:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-jwt-secret-key-64-characters-minimum
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-64-characters-minimum
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# Twilio Configuration (SMS/OTP)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# OpenAI Configuration (Advisory)
OPENAI_API_KEY=sk-your-openai-api-key

# Hugging Face Configuration (Disease Detection)
HUGGINGFACE_API_KEY=hf_your-huggingface-api-key

# Roboflow Configuration (Disease Detection Fallback)
ROBOFLOW_API_KEY=your-roboflow-api-key

# AWS Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET=agrinext-images-production

# Google Translate Configuration
GOOGLE_TRANSLATE_API_KEY=your-google-translate-api-key

# CORS Configuration
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# Session Configuration
SESSION_CLEANUP_INTERVAL=3600000
