# AgriNext Backend - Environment Configuration Template
# Copy this file to .env and replace all placeholder values

# Server Configuration
PORT=3000
NODE_ENV=development
API_VERSION=v1

# Database Configuration
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_NAME=agrinext_mvp
DB_USER=postgres
DB_PASSWORD=your-secure-database-password
DB_SSL=true
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT Secrets (Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your-jwt-secret-minimum-64-characters-long
REFRESH_TOKEN_SECRET=your-refresh-token-secret-minimum-64-characters-long
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=30d

# Twilio SMS (Get from: https://console.twilio.com)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# AWS S3 (Get from: AWS IAM Console)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# OpenAI (Get from: https://platform.openai.com/api-keys)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=500

# Hugging Face (Get from: https://huggingface.co/settings/tokens)
HUGGINGFACE_API_KEY=your-huggingface-api-key
HUGGINGFACE_MODEL=facebook/detr-resnet-50

# Roboflow (Optional - Get from: https://roboflow.com)
ROBOFLOW_API_KEY=your-roboflow-api-key
ROBOFLOW_PROJECT=plant-disease-detection
ROBOFLOW_VERSION=1

# Google Translate (Optional - Get from: https://console.cloud.google.com)
GOOGLE_PROJECT_ID=your-google-project-id

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# OTP Configuration
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3

# Logging
LOG_LEVEL=info

# CORS (Comma-separated list of allowed origins)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
